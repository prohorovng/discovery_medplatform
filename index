<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Медична Платформа — Discovery Record</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink:       #0F1923;
  --navy:      #1A3550;
  --blue:      #1D5F9E;
  --accent:    #C5472B;
  --gold:      #B8972A;
  --mist:      #EDF2F7;
  --paper:     #F9F7F4;
  --white:     #FFFFFF;
  --rule:      #D6DFE8;
  --low:       #2A7A4B;
  --mid:       #C08C00;
  --high:      #C5472B;
  --wf-bg:     #F0EEE9;
  --wf-box:    #D4CFC6;
  --wf-dark:   #8A8680;
  --wf-label:  #5C5952;
  --wf-accent: #1A3550;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { font-size: 16px; scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--paper);
  color: var(--ink);
  line-height: 1.65;
}

/* ── NAV ── */
nav {
  position: sticky; top: 0; z-index: 100;
  background: var(--navy);
  border-bottom: 2px solid var(--accent);
  padding: 0 2.5rem;
  display: flex; align-items: center; gap: 2rem;
}
.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem; font-weight: 700;
  color: var(--white); letter-spacing: .04em;
  padding: 1rem 0; white-space: nowrap;
  flex-shrink: 0;
}
.nav-logo span { color: #7AADCF; }
.nav-links {
  display: flex; gap: 0; flex-wrap: nowrap; overflow-x: auto;
  list-style: none; margin-left: auto;
}
.nav-links::-webkit-scrollbar { display: none; }
.nav-links a {
  display: block; padding: .85rem 1rem;
  font-size: .72rem; font-weight: 500; letter-spacing: .08em;
  text-transform: uppercase; color: #8CAEC8;
  text-decoration: none; white-space: nowrap;
  transition: color .2s;
  border-bottom: 2px solid transparent;
}
.nav-links a:hover { color: var(--white); border-bottom-color: var(--accent); }

/* ── HERO ── */
.hero {
  background: var(--navy);
  padding: 5rem 2.5rem 4rem;
  position: relative; overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; top: 0; right: 0;
  width: 55%; height: 100%;
  background: radial-gradient(ellipse at 80% 50%, rgba(29,95,158,.35) 0%, transparent 70%);
}
.hero-tag {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: .7rem; letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--accent); background: rgba(197,71,43,.12);
  border: 1px solid rgba(197,71,43,.35);
  padding: .3rem .8rem; border-radius: 2px;
  margin-bottom: 1.5rem;
}
.hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.4rem, 5vw, 4rem);
  font-weight: 700; line-height: 1.1;
  color: var(--white); max-width: 680px;
  margin-bottom: 1.2rem; position: relative;
}
.hero h1 em { color: #7AADCF; font-style: italic; }
.hero-sub {
  font-size: .95rem; color: #8CAEC8;
  max-width: 560px; margin-bottom: 2.5rem;
  position: relative;
}
.hero-meta {
  display: flex; flex-wrap: wrap; gap: 2rem;
  position: relative;
}
.meta-item { }
.meta-item .label {
  font-size: .68rem; letter-spacing: .1em; text-transform: uppercase;
  color: #5A7D96; margin-bottom: .2rem;
}
.meta-item .value {
  font-family: 'DM Mono', monospace;
  font-size: .82rem; color: #B8D0E0;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: .5rem;
  background: rgba(197,71,43,.15); border: 1px solid var(--accent);
  color: #F0A090; font-size: .75rem; font-weight: 500;
  padding: .4rem 1rem; border-radius: 2px; margin-top: 1.5rem;
}
.hero-badge::before { content: '⚠'; font-size: .9rem; }

/* ── LAYOUT ── */
.container { max-width: 1120px; margin: 0 auto; padding: 0 2.5rem; }

section { padding: 4.5rem 0; }
section + section { border-top: 1px solid var(--rule); }

/* ── SECTION HEADERS ── */
.section-label {
  font-family: 'DM Mono', monospace;
  font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
  color: var(--accent); margin-bottom: .6rem;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 700; color: var(--navy);
  margin-bottom: 1rem; line-height: 1.2;
}
.section-lead {
  font-size: .95rem; color: #4A5A6A;
  max-width: 640px; line-height: 1.75;
  margin-bottom: 2.5rem;
}

/* ── CALLOUT BOX ── */
.callout {
  background: var(--mist); border-left: 3px solid var(--blue);
  padding: 1.2rem 1.5rem; margin: 1.5rem 0;
  border-radius: 0 4px 4px 0;
}
.callout p { font-size: .9rem; color: #2A3D52; line-height: 1.7; }
.callout.warn { border-left-color: var(--accent); background: #FEF5F3; }
.callout.warn p { color: #6B1A10; }
.callout.gold { border-left-color: var(--gold); background: #FEF9ED; }
.callout.gold p { color: #5C4300; }

/* ── TAGS ── */
.tag {
  display: inline-block;
  font-size: .67rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase;
  padding: .2rem .55rem; border-radius: 2px;
}
.tag-mvp1 { background: #E8F4EC; color: #1A5E2A; border: 1px solid #9BCBA8; }
.tag-mvp2 { background: #EEF4FB; color: #1A3D6E; border: 1px solid #94B8DC; }
.tag-v3   { background: #F5F0FF; color: #4A2585; border: 1px solid #B5A0D8; }
.tag-open { background: #FEF9ED; color: #7A4B00; border: 1px solid #D4AC50; }
.tag-high { background: #FDEEEA; color: #8B2215; border: 1px solid #E8A090; }
.tag-mid  { background: #FEF8E0; color: #7A5800; border: 1px solid #D4B84A; }
.tag-low  { background: #E8F5EE; color: #185A2E; border: 1px solid #7ECA9A; }

/* ── PROBLEM / NEED GRID ── */
.need-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1.5px; background: var(--rule);
  border: 1px solid var(--rule); margin-top: 2rem;
}
.need-item {
  background: var(--white); padding: 1.5rem;
  display: flex; gap: 1rem; align-items: flex-start;
}
.need-icon {
  width: 36px; height: 36px; flex-shrink: 0;
  background: var(--mist); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
}
.need-item h4 { font-size: .85rem; font-weight: 600; color: var(--navy); margin-bottom: .3rem; }
.need-item p  { font-size: .82rem; color: #556070; line-height: 1.6; }

/* ── MODULES TABLE ── */
.modules-table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; font-size: .83rem; }
.modules-table th {
  background: var(--navy); color: var(--white);
  padding: .75rem 1rem; text-align: left;
  font-size: .72rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase;
}
.modules-table td {
  padding: .8rem 1rem; border-bottom: 1px solid var(--rule);
  vertical-align: top; color: var(--ink);
}
.modules-table tr:nth-child(even) td { background: #FAFBFC; }
.modules-table tr:hover td { background: var(--mist); }
.modules-table td:first-child { font-weight: 600; color: var(--navy); white-space: nowrap; }
.modules-table td.mono { font-family: 'DM Mono', monospace; font-size: .78rem; color: #3A5060; }

/* ── ROLES ── */
.roles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
.role-card {
  background: var(--white); border: 1px solid var(--rule);
  padding: 1.5rem; border-radius: 2px;
  position: relative; overflow: hidden;
}
.role-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 3px; background: var(--blue);
}
.role-card.admin::before  { background: var(--accent); }
.role-card.doctor::before { background: var(--gold); }
.role-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.25rem; font-weight: 700;
  color: var(--navy); margin-bottom: .25rem;
}
.role-card .role-tag {
  font-size: .68rem; color: #7A8A9A; font-family: 'DM Mono', monospace;
  letter-spacing: .08em; text-transform: uppercase; margin-bottom: .8rem;
}
.role-card ul { list-style: none; }
.role-card li {
  font-size: .82rem; color: #3A4A5A; padding: .3rem 0;
  border-bottom: 1px solid #F0F0F0; display: flex; gap: .6rem;
}
.role-card li:last-child { border: none; }
.role-card li::before { content: '→'; color: var(--blue); flex-shrink: 0; font-size: .75rem; }

/* ── PAYMENT FLOW ── */
.flow-steps {
  display: flex; align-items: stretch; gap: 0;
  margin: 2rem 0; flex-wrap: wrap;
}
.flow-step {
  flex: 1; min-width: 150px;
  background: var(--white); border: 1px solid var(--rule);
  padding: 1.2rem 1rem; text-align: center;
  position: relative;
}
.flow-step + .flow-step {
  border-left: none;
}
.flow-step::after {
  content: '→'; position: absolute;
  right: -14px; top: 50%; transform: translateY(-50%);
  font-size: 1.2rem; color: var(--blue); z-index: 2;
  background: var(--paper); padding: 0 2px;
}
.flow-step:last-child::after { display: none; }
.flow-num {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--navy); color: var(--white);
  font-family: 'DM Mono', monospace; font-size: .75rem; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto .6rem;
}
.flow-step h4 { font-size: .8rem; font-weight: 600; color: var(--navy); margin-bottom: .3rem; }
.flow-step p  { font-size: .75rem; color: #5A6A7A; line-height: 1.5; }

/* ── MVP TABLE ── */
.mvp-table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; font-size: .83rem; }
.mvp-table th {
  background: var(--navy); color: var(--white);
  padding: .7rem 1rem; text-align: left;
  font-size: .7rem; font-weight: 600; letter-spacing: .07em; text-transform: uppercase;
}
.mvp-table td {
  padding: .75rem 1rem; border-bottom: 1px solid var(--rule); vertical-align: middle;
}
.mvp-table tr:nth-child(even) td { background: #FAFBFC; }
.mvp-table td.check { text-align: center; font-size: 1rem; }
.check-yes { color: var(--low); }
.check-no  { color: #BBC5CE; }

/* ── RISK TABLE ── */
.risk-table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; font-size: .83rem; }
.risk-table th {
  background: #1F0D0A; color: var(--white);
  padding: .75rem 1rem; text-align: left;
  font-size: .7rem; letter-spacing: .07em; text-transform: uppercase; font-weight: 600;
}
.risk-table td {
  padding: .85rem 1rem; border-bottom: 1px solid var(--rule); vertical-align: top;
}
.risk-table tr:nth-child(even) td { background: #FAFBFC; }

/* ── ASSUMPTIONS ── */
.assumption-list { list-style: none; margin-top: 1.5rem; }
.assumption-list li {
  display: grid; grid-template-columns: 80px 1fr;
  gap: 1rem; padding: 1rem 0;
  border-bottom: 1px solid var(--rule);
  font-size: .85rem;
}
.assumption-list li:last-child { border: none; }
.a-code {
  font-family: 'DM Mono', monospace; font-size: .8rem;
  font-weight: 500; color: var(--blue);
  background: var(--mist); padding: .2rem .5rem;
  border-radius: 2px; text-align: center;
  align-self: start; white-space: nowrap;
}
.a-text { color: #2A3A4A; line-height: 1.65; }
.a-text strong { color: var(--navy); }

/* ── NEXT STEPS ── */
.steps-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
.step-block {
  background: var(--white); border: 1px solid var(--rule); padding: 1.5rem;
}
.step-block h3 {
  font-size: .85rem; font-weight: 700; color: var(--navy);
  text-transform: uppercase; letter-spacing: .07em;
  margin-bottom: 1rem; padding-bottom: .5rem;
  border-bottom: 2px solid var(--rule);
}
.step-block ul { list-style: none; }
.step-block li {
  font-size: .83rem; color: #3A4A5A; padding: .4rem 0;
  border-bottom: 1px dashed #E8E8E8;
  display: flex; gap: .6rem; align-items: flex-start;
}
.step-block li:last-child { border: none; }
.step-block li::before { content: '▸'; color: var(--accent); flex-shrink: 0; font-size: .7rem; margin-top: .15rem; }

/* ══════════════════════════════════════════
   WIREFRAMES
══════════════════════════════════════════ */
#wireframes { background: #F0EEE9; }
#wireframes .section-title { color: #2A2520; }

.wf-intro-note {
  background: #E8E5DF; border: 1px solid #C8C4BC;
  padding: 1rem 1.4rem; margin-bottom: 2.5rem;
  font-size: .82rem; color: var(--wf-label);
  font-family: 'DM Mono', monospace;
}

.wf-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem; }
.wf-grid.single { grid-template-columns: 1fr; }

.wf-card {
  background: var(--white); border: 1px solid #C8C4BC;
  box-shadow: 3px 3px 0 #C8C4BC;
}
.wf-card-header {
  background: var(--wf-dark); color: var(--white);
  padding: .6rem 1rem;
  display: flex; align-items: center; justify-content: space-between;
}
.wf-card-header .wf-title {
  font-family: 'DM Mono', monospace;
  font-size: .75rem; letter-spacing: .08em; text-transform: uppercase;
}
.wf-card-header .wf-num {
  font-family: 'DM Mono', monospace;
  font-size: .68rem; color: #A8A49C;
}
.wf-frame {
  padding: 1.2rem; background: var(--wf-bg);
}

/* Wireframe primitives */
.wf-browser {
  background: #E8E4DE; border: 1.5px solid var(--wf-box);
  border-radius: 2px; overflow: hidden;
}
.wf-browser-bar {
  background: #D0CCc4; padding: .4rem .7rem;
  display: flex; align-items: center; gap: .5rem;
}
.wf-dot { width: 8px; height: 8px; border-radius: 50%; background: #AAA5A0; }
.wf-url {
  flex: 1; height: 14px; background: #E8E4DE;
  border: 1px solid #B8B4AC; border-radius: 1px;
  margin-left: .3rem;
}
.wf-body { padding: 0; }

/* Generic wireframe boxes */
.wf-nav {
  background: var(--wf-dark); height: 36px;
  display: flex; align-items: center; padding: 0 .8rem; gap: .8rem;
}
.wf-nav-logo { width: 80px; height: 14px; background: #A0A09A; border-radius: 1px; }
.wf-nav-links { display: flex; gap: .5rem; margin-left: auto; }
.wf-nav-link { width: 44px; height: 10px; background: #7A7870; border-radius: 1px; }
.wf-nav-btn { width: 56px; height: 20px; background: #C5472B; border-radius: 1px; }

.wf-hero-block { background: #5A6878; padding: 1.2rem .8rem; text-align: center; }
.wf-h1  { height: 18px; background: #C8D0DA; border-radius: 1px; margin: 0 auto .6rem; }
.wf-h2  { height: 13px; background: #A8B0B8; border-radius: 1px; margin: 0 auto .5rem; }
.wf-h3  { height: 11px; background: #8A9098; border-radius: 1px; margin: 0 auto .4rem; }
.wf-p   { height: 9px;  background: #9098A0; border-radius: 1px; margin: 0 auto .3rem; }
.wf-btn {
  display: inline-block; padding: .4rem .9rem;
  background: #C5472B; border-radius: 1px;
  font-family: 'DM Mono', monospace; font-size: .65rem;
  color: var(--white); margin-top: .5rem;
}
.wf-btn.secondary {
  background: transparent; border: 1.5px solid #A8ADB2; color: #A8ADB2;
}
.wf-divider { height: 1px; background: var(--wf-box); margin: .8rem 0; }
.wf-section { padding: .8rem; }
.wf-row { display: flex; gap: .6rem; margin-bottom: .6rem; align-items: flex-start; }
.wf-col { flex: 1; }
.wf-box {
  background: var(--wf-box); border-radius: 1px;
  display: flex; align-items: center; justify-content: center;
}
.wf-box.img { background: #C8C4BA; }
.wf-label {
  font-family: 'DM Mono', monospace; font-size: .6rem;
  color: var(--wf-label); text-align: center; padding: .2rem;
}
.wf-input {
  height: 24px; background: var(--white);
  border: 1.5px solid var(--wf-box); border-radius: 1px;
  margin-bottom: .4rem; width: 100%;
}
.wf-input-label { height: 8px; background: var(--wf-dark); border-radius: 1px; width: 50%; margin-bottom: .25rem; opacity: .5; }
.wf-card-inner {
  background: var(--white); border: 1px solid var(--wf-box);
  border-radius: 1px; padding: .6rem;
}
.wf-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--wf-box); flex-shrink: 0; }
.wf-stars { color: #C8A830; font-size: .75rem; }
.wf-badge {
  display: inline-block; padding: .15rem .4rem;
  background: #D0E8D8; border-radius: 1px;
  font-family: 'DM Mono', monospace; font-size: .58rem; color: #2A5A38;
}
.wf-tag-box {
  display: inline-block; padding: .1rem .35rem;
  background: var(--wf-box); border-radius: 1px;
  font-family: 'DM Mono', monospace; font-size: .58rem; color: var(--wf-label);
  margin: .1rem;
}
.wf-sidebar {
  width: 80px; flex-shrink: 0;
  background: #D8D4CC; padding: .5rem; border-right: 1px solid var(--wf-box);
}
.wf-sidebar-item {
  height: 22px; background: #C0BDB5; border-radius: 1px;
  margin-bottom: .4rem; display: flex; align-items: center;
  padding: 0 .4rem;
}
.wf-sidebar-item.active { background: var(--wf-accent); }
.wf-sidebar-label { height: 7px; background: #A0A09A; border-radius: 1px; width: 80%; }
.wf-sidebar-item.active .wf-sidebar-label { background: #C0D8E8; }
.wf-stat-block {
  background: var(--white); border: 1px solid var(--wf-box);
  padding: .5rem; flex: 1; text-align: center;
}
.wf-stat-num { height: 18px; background: var(--wf-accent); border-radius: 1px; width: 60%; margin: 0 auto .3rem; opacity: .5; }
.wf-stat-lbl { height: 7px; background: var(--wf-box); border-radius: 1px; width: 80%; margin: 0 auto; }

.wf-annotation {
  margin-top: .8rem;
  background: #F8F5F0; border: 1px dashed #C8C4BC;
  padding: .6rem .8rem;
}
.wf-annotation ul { list-style: none; }
.wf-annotation li {
  font-family: 'DM Mono', monospace;
  font-size: .62rem; color: var(--wf-label);
  padding: .2rem 0; border-bottom: 1px dashed #E0DDD8;
  display: flex; gap: .5rem;
}
.wf-annotation li:last-child { border: none; }
.wf-annotation li::before { content: '↳'; color: #C5472B; }

.wf-screen-label {
  background: var(--wf-accent); color: var(--white);
  font-family: 'DM Mono', monospace; font-size: .62rem;
  letter-spacing: .1em; text-transform: uppercase;
  padding: .25rem .6rem; display: inline-block; margin-bottom: .5rem;
}

/* ── COMPETITORS ── */
.comp-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
.comp-card {
  background: var(--white); border: 1px solid var(--rule); padding: 1.3rem;
}
.comp-card h4 { font-size: .95rem; font-weight: 700; color: var(--navy); margin-bottom: .5rem; }
.comp-card .comp-strength { font-size: .8rem; color: #3A5A2A; margin-bottom: .4rem; }
.comp-card .comp-gap { font-size: .8rem; color: var(--accent); }
.comp-card .comp-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #8A9AA8; margin-bottom: .2rem; }

/* ── FOOTER ── */
footer {
  background: var(--navy); color: #6A8AA0;
  padding: 2.5rem; text-align: center;
  border-top: 2px solid var(--accent);
}
footer p { font-size: .78rem; line-height: 1.8; }
footer strong { color: #B0CCE0; }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .need-grid, .roles-grid, .steps-grid, .comp-grid, .wf-grid { grid-template-columns: 1fr; }
  .flow-steps { flex-direction: column; }
  .flow-step::after { display: none; }
  .nav-links { display: none; }
  .container { padding: 0 1.2rem; }
  .hero { padding: 3rem 1.2rem; }
  section { padding: 3rem 0; }
}

/* Fade-in on load */
@keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.fade { animation: fadeUp .5s ease both; }
.fade:nth-child(2) { animation-delay: .1s; }
.fade:nth-child(3) { animation-delay: .2s; }
.fade:nth-child(4) { animation-delay: .3s; }
</style>
</head>
<body>

